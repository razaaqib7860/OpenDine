<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>URL Analytics</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;
}

body{
    background:#f4f6f9;
    padding:40px;
}

.container{
    width:1100px;
    margin:auto;
}

h1{
    text-align:center;
    margin-bottom:35px;
    color:#222;
}

.cards{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:10px;
    margin-bottom:35px;
}

.card{
    background:white;
    padding:15px;
    height:150px;
    border-radius:10px;
    box-shadow:0 5px 15px rgba(0,0,0,.1);
    text-align:center;
}

.card h3{
    color:#666;
    margin-bottom:1px;
}

.card h2{
    color:#007bff;
    font-size:80px;
}

.last-click{
    font-size:40px !important;
    line-height:1.4;
    word-wrap:break-word;
}


.info{
    background:white;
    padding:25px;
    border-radius:12px;
    box-shadow:0 5px 15px rgba(0,0,0,.1);
}

.info h3{
    margin-bottom:20px;
}

.info p{
    margin:12px 0;
}

.url{
    background:#eee;
    padding:12px;
    border-radius:8px;
    word-break:break-all;
}

.back{
    display:inline-block;
    margin-top:30px;
    padding:12px 20px;
    background:#28a745;
    color:white;
    text-decoration:none;
    border-radius:8px;
}

.back:hover{
    background:#218838;
}

</style>

</head>
<body>

<div class="container">

<h1>📊 URL Analytics</h1>

<div class="cards">

    <div class="card">
        <h3>Total Clicks</h3>
        <h2><%= url.clicks %></h2>
    </div>

    <div class="card">
        <h3>Today's Clicks</h3>
        <h2><%= url.clicks %></h2>
    </div>

   <div class="card">
    <h3>Last Click</h3>

    <% if (url.visitHistory.length > 0) { %>

        <h2 class="last-click">

<%= new Date(url.visitHistory[url.visitHistory.length - 1].timestamp)
    .toLocaleDateString('en-IN', {
        timeZone: 'Asia/Kolkata',
        day: '2-digit',
        month: 'short',
        year: 'numeric'
    }) %>

<br>

<%= new Date(url.visitHistory[url.visitHistory.length - 1].timestamp)
    .toLocaleTimeString('en-IN', {
        timeZone: 'Asia/Kolkata',
        hour: '2-digit',
        minute: '2-digit',
        hour12: true
    }) %>

        </h2>

    <% } else { %>

        <h2 class="last-click">No Clicks Yet</h2>

    <% } %>

</div>

</div>


<div class="info">

    <h3>URL Details</h3>

    <p><strong>Original URL</strong></p>

    <div class="url">
       <%= url.originalUrl %>
    </div>

    <br>

    <p><strong>Short URL</strong></p>

    <div class="url">
        <%= url.shortUrl %>
    </div>

</div>

<a href="/UrlShortner" class="back">
    ← Generate Another URL
</a>

</div>

<script>

const ctx = document.getElementById("clickChart");

new Chart(ctx,{
    type:"line",

    data:{
        labels:["Mon","Tue","Wed","Thu","Fri","Sat","Sun"],

        datasets:[{
            label:"Clicks",
            data:[5,8,12,18,22,16,30],
            borderWidth:3,
            tension:.4,
            fill:false
        }]
    },

    options:{
        responsive:true
    }

});

</script>

</body>
</html>
