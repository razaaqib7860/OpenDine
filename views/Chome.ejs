<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>OpenDine</title>

    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">

    <link rel="stylesheet" href="/css/home.css">
</head>

<body>

    <div class="hero-background"></div>

    <header class="navbar">

        <div class="nav-left">

            <a href="/" class="logo">
                <i class="fa-solid fa-champagne-glasses"></i>
                OpenDine
            </a>

            <nav class="nav-links">
                <a href="/" class="active">Discover</a>
                <a href="/restaurant">Restaurants</a>
                <a href="/booking">My Bookings</a>
            </nav>

        </div>

        <div class="nav-right">

            <% if(!user){ %>

                <a href="/user/login" class="login-btn">
                    <i class="fa-solid fa-user"></i>
                    Login
                </a>

            <% } else { %>

                <div class="profile">

                    <button class="profile-trigger">

                        <div class="avatar">
                            <%= user.Name.charAt(0).toUpperCase() %>
                        </div>

                        <span>
                            <%= user.Name %>
                        </span>

                        <i class="fa-solid fa-chevron-down"></i>

                    </button>

                    <div class="profile-dropdown">

                        <div class="user-info">
                            <h4><%= user.Name %></h4>
                            <p><%= user.email %></p>
                        </div>

                        <hr>

                        <a href="/user/profile" class="dropdown-item">
                            <i class="fa-solid fa-user"></i>
                            My Profile
                        </a>

                        <a href="/booking" class="dropdown-item">
                            <i class="fa-regular fa-calendar-check"></i>
                            My Bookings
                        </a>

                        <% if(user.role==="owner"){ %>

                            <a href="/owner/dashboard" class="dropdown-item">
                                <i class="fa-solid fa-store"></i>
                                Owner Dashboard
                            </a>

                        <% } %>

                        <hr>

                        <a href="/user/logout" class="dropdown-item logout">
                            <i class="fa-solid fa-arrow-right-from-bracket"></i>
                            Logout
                        </a>

                    </div>

                </div>

            <% } %>

        </div>

    </header>

    <main class="hero-section">

        <div class="hero-content">

            <p class="subtitle">
                EXQUISITE DINING EXPERIENCES
            </p>

            <h1 class="main-heading">
                Curation for the <br>
                Discerning Palette
            </h1>

        </div>

        <div class="search-widget">

            <div class="input-group">
                <i class="fa-solid fa-magnifying-glass icon"></i>
                <input type="text"
                    placeholder="Search cuisines, restaurants...">
            </div>

            <div class="input-group border-left">
                <i class="fa-solid fa-location-dot icon"></i>
                <input type="text"
                    placeholder="Location (e.g. Hyderabad)">
            </div>

            <div class="input-group border-left">
                <i class="fa-regular fa-calendar icon"></i>
                <input type="date">
            </div>

            <div class="input-group border-left">
                <i class="fa-solid fa-user-group icon"></i>

                <select>
                    <option>1 Guest</option>
                    <option selected>2 Guests</option>
                    <option>3 Guests</option>
                    <option>4+ Guests</option>
                </select>

            </div>

            <button class="search-btn">
                FIND A TABLE
            </button>

        </div>

    </main>

    <!-- Restaurants section will come here -->

</body>
</html>