<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>OpenDine</title>

    <!-- CSS -->
    <link rel="stylesheet" href="/css/home.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"
    >

</head>
<body>

    <!-- NAVBAR -->

    <nav>

        <div class="logo">
            <a href="/">
                🍽 OpenDine
            </a>
        </div>

        <div class="search-location">

            <div class="location">

                <i class="fa-solid fa-location-dot"></i>

                <select>

                    <option>Ranchi</option>
                    <option>Delhi</option>
                    <option>Mumbai</option>
                    <option>Bangalore</option>
                    <option>Hyderabad</option>

                </select>

            </div>

            <div class="search-box">

                <i class="fa-solid fa-magnifying-glass"></i>

                <input
                    type="text"
                    placeholder="Search restaurants, cuisines, dishes..."
                >

            </div>

        </div>

        <div class="nav-links">

            <a href="/">Home</a>

            <a href="/restaurants">Restaurants</a>

            <a href="/offers">Offers</a>

            <a href="/about">About</a>

        </div>

        <div class="login">
<!-- <%= JSON.stringify(user) %> -->

            <% if(user){ %>

                <a href="/profile">
                    <i class="fa-solid fa-user"></i>
                    <%= user.Name %>
                </a>

            <% } else { %>

                <a href="/user/login">
                    <i class="fa-solid fa-user"></i>
                    Login
                </a>

            <% } %>

        </div>

    </nav>



    
    <!-- HERO SECTION -->

<section class="hero">

    <!-- Background Slider -->
    <div class="hero-slider">

        <img src="/images/img.jpg" class="hero-img active">
        <img src="/images/hero.jpg" class="hero-img">
        <img src="/images/img3.jpg" class="hero-img">
        <img src="/images/img1.jpg" class="hero-img">
        <!-- <img src="/images/img2.jpg" class="hero-img"> -->

    </div>


    <div class="overlay"></div>


    <div class="hero-content">

        <h1>
            Reserve Your Perfect Dining Experience
        </h1>

        <p>
            Discover the best restaurants, book tables instantly,
            and enjoy unforgettable dining moments.
        </p>

        <div class="hero-buttons">
            <a href="/restaurants" class="btn-primary">
                Book a Table
            </a>

            <a href="/restaurants" class="btn-secondary">
                Explore Restaurants
            </a>
        </div>

    </div>

</section>
 
<script src="/js/home.js"></script>

</body>
</html>